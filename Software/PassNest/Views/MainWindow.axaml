<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PassNest.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="using:PassNest.Views"
        mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="670"
        x:Class="PassNest.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/PassNest-icon.ico"
        Title="PassNest"
        Width="600"
        Height="670"
        CanResize="False"
        WindowStartupLocation="CenterScreen">

    <Design.DataContext>
       <vm:MainWindowViewModel/>
    </Design.DataContext>

    <views:RegisterView>
        <views:RegisterView.DataContext>
            <vm:RegisterViewModel/>
        </views:RegisterView.DataContext>
    </views:RegisterView>
</Window>
