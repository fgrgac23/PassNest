<UserControl xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PassNest.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="using:PassNest.Views"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="670"
        x:Class="PassNest.Views.TwoFactorView"
        x:Name="Root"
        x:DataType="vm:TwoFactorViewModel">

    <Design.DataContext>
        <vm:TwoFactorViewModel/>
    </Design.DataContext>

    <Grid Width="600" Height="600" RowDefinitions="Auto,*" Background="{StaticResource Canvas}">
        <Border Grid.Row="0" Background="{StaticResource GraphiteDark}" Padding="24,16">
            <TextBlock Text="PassNest - 2FA" FontFamily="{StaticResource PlexSans}" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextOnDarkPrimary}"/>
        </Border>
        <ScrollViewer Grid.Row="1">
            <StackPanel Margin="40,32,40,32" HorizontalAlignment="Center" Width="440" Spacing="24">
                <Image Source="avares://PassNest/Assets/PassNest-Logo.png" Height="100" Stretch="Uniform" HorizontalAlignment="Center"/>
                <StackPanel Spacing="6" HorizontalAlignment="Center">
                    <TextBlock Text="Unesite kod" FontFamily="{StaticResource PlexSans}" FontWeight="Bold" FontSize="22" Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Center"/>
                    <TextBlock FontFamily="{StaticResource PlexSans}" FontSize="13" Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center" TextAlignment="Center">
                        <Run Text="Poslali smo jednokratni kod na"/>
                        <LineBreak/>
                        <Run Text="{Binding MaskedEmail}" FontFamily="{StaticResource PlexMono}" Foreground="{StaticResource TextPrimary}"/>
                    </TextBlock>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                    <TextBox Classes="otp-digit" Classes.filled="{Binding IsDigit1Filled}" Text="{Binding Digit1}">
                        <TextBox.Resources>
                            <SolidColorBrush x:Key="TextControlBorderBrushFocused">Transparent</SolidColorBrush>
                            <SolidColorBrush x:Key="TextControlBorderBrushPointOver">Transparent</SolidColorBrush>
                        </TextBox.Resources>
                    </TextBox>
                    <TextBox Classes="otp-digit" Classes.filled="{Binding IsDigit2Filled}" Text="{Binding Digit2}">
                        <TextBox.Resources>
                            <SolidColorBrush x:Key="TextControlBorderBrushFocused">Transparent</SolidColorBrush>
                            <SolidColorBrush x:Key="TextControlBorderBrushPointOver">Transparent</SolidColorBrush>
                        </TextBox.Resources>
                    </TextBox>
                    <TextBox Classes="otp-digit" Classes.filled="{Binding IsDigit3Filled}" Text="{Binding Digit3}">
                        <TextBox.Resources>
                            <SolidColorBrush x:Key="TextControlBorderBrushFocused">Transparent</SolidColorBrush>
                            <SolidColorBrush x:Key="TextControlBorderBrushPointOver">Transparent</SolidColorBrush>
                        </TextBox.Resources>
                    </TextBox>
                    <TextBox Classes="otp-digit" Classes.filled="{Binding IsDigit4Filled}" Text="{Binding Digit4}">
                        <TextBox.Resources>
                            <SolidColorBrush x:Key="TextControlBorderBrushFocused">Transparent</SolidColorBrush>
                            <SolidColorBrush x:Key="TextControlBorderBrushPointOver">Transparent</SolidColorBrush>
                        </TextBox.Resources>
                    </TextBox>
                    <TextBox Classes="otp-digit" Classes.filled="{Binding IsDigit5Filled}" Text="{Binding Digit5}">
                        <TextBox.Resources>
                            <SolidColorBrush x:Key="TextControlBorderBrushFocused">Transparent</SolidColorBrush>
                            <SolidColorBrush x:Key="TextControlBorderBrushPointOver">Transparent</SolidColorBrush>
                        </TextBox.Resources>
                    </TextBox>
                    <TextBox Classes="otp-digit" Classes.filled="{Binding IsDigit6Filled}" Text="{Binding Digit6}">
                        <TextBox.Resources>
                            <SolidColorBrush x:Key="TextControlBorderBrushFocused">Transparent</SolidColorBrush>
                            <SolidColorBrush x:Key="TextControlBorderBrushPointOver">Transparent</SolidColorBrush>
                        </TextBox.Resources>
                    </TextBox>
                </StackPanel>
                <Button Classes="primary" Content="Potvrdi i prijavi se" Command="{Binding ConfirmCodeCommand}" HorizontalAlignment="Stretch"/>
                <TextBlock HorizontalAlignment="Center" FontFamily="{StaticResource PlexSans}" FontSize="13" Foreground="{StaticResource TextSecondary}">
                    <Run Text="Ponovno pošalji kod za "/>
                    <Run Text="{Binding ResendCountdown}" FontWeight="Bold" Foreground="{StaticResource Medium}"/>
                </TextBlock>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>