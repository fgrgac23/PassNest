<Styles xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style Selector="TextBlock.field-label">
        <Setter Property="FontFamily" Value="{StaticResource PlexSans}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        <Setter Property="Margin" Value="0,0,0,6"/>
    </Style>

    <Style Selector="TextBox.form">
        <Setter Property="FontFamily" Value="{StaticResource PlexSans}"/>
        <Setter Property="Padding" Value="12,10"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
        <Setter Property="Background" Value="{StaticResource Surface}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
    </Style>

    <Style Selector="TextBox.form:focus">
        <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
    </Style>

    <Style Selector="Button.primary">
        <Setter Property="FontFamily" Value="{StaticResource PlexSans}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="Padding" Value="0,14"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Background" Value="{StaticResource Accent}"/>
        <Setter Property="Foreground" Value="{StaticResource TextOnDarkPrimary}"/>
    </Style>

    <Style Selector="Button.primary:pointerover">
        <Setter Property="Background" Value="{StaticResource AccentHover}"/>
    </Style>

     <Style Selector="Button.secondary">
        <Setter Property="FontFamily" Value="{StaticResource PlexSans}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderStrong}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Padding" Value="0,14"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
    </Style>

    <Style Selector="Button.icon-toggle">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="4"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Template">
           <ControlTemplate>
              <ContentPresenter Content="{TemplateBinding Content}" Padding="{TemplateBinding Padding}" HorizontalAlignment="Center" VerticalAlignment="Center"/> 
           </ControlTemplate> 
        </Setter>
    </Style>

    <Style Selector="TextBlock.sidebar-label">
        <Setter Property="FontFamily" Value="{StaticResource PlexSans}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource TextOnDarkMuted}"/>
        <Setter Property="LetterSpacing" Value="1"/>
        <Setter Property="Margin" Value="12,0,0,4"/>
    </Style>

    <Style Selector="Button.nav-item">
        <Setter Property="FontFamily" Value="{StaticResource PlexSans}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Padding" Value="12,10"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextOnDarkMuted}"/> 
    </Style>

    <Style Selector="Button.nav-item:pointerover">
        <Setter Property="Background" Value="{StaticResource Graphite}"/>
        <Setter Property="Foreground" Value="{StaticResource TextOnDarkPrimary}"/>
    </Style>

    <Style Selector="Button.nav-item.active">
        <Setter Property="Background" Value="{StaticResource Graphite}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
        <Setter Property="Foreground" Value="{StaticResource TextOnDarkPrimary}"/> 
    </Style>

    <Style Selector="Button.category-item">
        <Setter Property="FontFamily" Value="{StaticResource PlexSans}"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextOnDarkMuted}"/> 
    </Style>

    <Style Selector="Button.category-item:pointerover">
        <Setter Property="Background" Value="{StaticResource Graphite}"/> 
        <Setter Property="Foreground" Value="{StaticResource TextOnDarkPrimary}"/>
    </Style>

    <Style Selector="Button.category-item.active">
        <Setter Property="Background" Value="{StaticResource Graphite}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
        <Setter Property="Foreground" Value="{StaticResource TextOnDarkPrimary}"/> 
    </Style>

    <Style Selector="Button.icon-action">
        <Setter Property="Width" Value="34"/>
        <Setter Property="Height" Value="34"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <Style Selector="Button.icon-action:pointerover">
        <Setter Property="Background" Value="{StaticResource Canvas}"/>
    </Style>

    <Style Selector="Button.icon-action-accent">
        <Setter Property="Width" Value="34"/>
        <Setter Property="Height" Value="34"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
        <Setter Property="Background" Value="{StaticResource AccentTint}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <Style Selector="Button.icon-action-accent:pointerover">
        <Setter Property="Background" Value="{StaticResource Accent}"/>
    </Style>

    <Style Selector="Button.secondary-dark">
        <Setter Property="FontFamily" Value="{StaticResource PlexSans}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Padding" Value="0,12"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="{StaticResource Graphite}"/>
        <Setter Property="Foreground" Value="{StaticResource TextOnDarkMuted}"/> 
    </Style>

    <Style Selector="Button.secondary-dark:pointerover">
        <Setter Property="Background" Value="{StaticResource Graphite}"/>
    </Style>

    <Style Selector="Border.account-card">
        <Setter Property="Background" Value="{StaticResource Surface}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="Width" Value="270"/>
        <Setter Property="BoxShadow" Value="0 1 3 0 #14000000"/>
    </Style>

    <Style Selector="Border.account-card:pointerover">
       <Setter Property="BorderBrush" Value="{StaticResource BorderStrong}"/>
       <Setter Property="BoxShadow" Value="0 4 12 0 #1F000000"/>
    </Style>
</Styles>